# ── Clawome Environment Configuration ──
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider (required for Task Agent) ──
# API key for OpenAI-compatible LLM endpoint
LLM_API_KEY=

# API base URL (OpenAI-compatible endpoint)
# Examples:
#   https://dashscope.aliyuncs.com/compatible-mode/v1  (Alibaba Cloud / Qwen)
#   https://api.openai.com/v1                          (OpenAI)
#   https://api.deepseek.com                           (DeepSeek)
LLM_API_BASE=

# Model name (e.g. qwen3.5-plus, gpt-4o, deepseek-chat)
LLM_MODEL=qwen3.5-plus

# ── Optional ──
# LLM temperature (0 = deterministic, default: 0)
# LLM_TEMPERATURE=0

# Max tokens per LLM response (default: 4096)
# LLM_MAX_TOKENS=4096

# Browser start URL for Task Agent (default: https://www.baidu.com)
# AGENT_START_URL=https://www.baidu.com

# Max steps per subtask (default: 15)
# AGENT_MAX_STEPS=15
